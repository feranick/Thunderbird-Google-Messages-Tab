{
  "manifest_version": 2,
  "name": "Google Messages Tab",
  "description": "__MSG_extensionDescription__",
  "version": "0.4",
  "author": "Nicola Ferralis",
  "homepage_url": "https://github.com/feranick/Thunderbird-Google-Messages-Tab/",
  "browser_specific_settings": {
    "gecko": {
      "id": "feranick.google-messages-tab@addons.thunderbird.net",
      "strict_min_version": "106.0"
    }
  },  
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "menus",
    "https://*.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://messages.google.com/web/*"],
      "js": ["content.js"]
    }
  ],
  "default_locale": "en",
  "icons": {
    "32": "skin/google_messages_icon.svg",
    "48": "skin/google_messages_icon.svg",
    "96": "skin/google_messages_icon.svg"
  },
  "background": {
    "scripts": [
      "redirect.js"
    ]
  }
}
